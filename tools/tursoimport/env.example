# Copy this file to tools/tursoimport/.env.local and fill the real values.

TURSOIMPORT_TURSO_URL=https://your-database.turso.io
TURSOIMPORT_TURSO_TOKEN=your-turso-token
TURSOIMPORT_TARGET_DATABASE_URL=postgres://user:password@host:5432/database

# Optional. Relative paths resolve from tools/tursoimport.
# TURSOIMPORT_SQLITE_PATH=.tmp/legacy-turso.db
# TURSOIMPORT_REMOTE_PROBE_TIMEOUT_MS=15000
# TURSOIMPORT_SYNC_TIMEOUT_MS=300000
# TURSOIMPORT_TARGET_DATABASE_TLS=true
