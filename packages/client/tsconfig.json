{
    "extends": "../../tsconfig.package.json",
    "compilerOptions": {
        "outDir": "dist",
        "rootDir": "src",
        "jsx": "react-jsx",
        "lib": ["DOM", "DOM.Iterable", "ESNext"],
        "paths": {
            "@/*": ["./src/*"],
            "$/*": ["../../tests/*"]
        },
        "declaration": false,
        "declarationMap": false
    },
    "include": ["src"]
}
