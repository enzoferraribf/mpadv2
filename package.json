{
    "name": "mpad",
    "private": true,
    "packageManager": "bun@1.3.11",
    "workspaces": [
        "packages/client",
        "packages/server",
        "packages/legacy-import",
        "packages/core",
        "packages/protocol",
        "packages/text-core",
        "packages/testkit"
    ],
    "scripts": {
        "dev": "turbo dev",
        "build": "turbo build",
        "legacy:import": "cd packages/legacy-import && bun run import",
        "server:schema-migrate": "cd packages/server && bun run schema-migrate",
        "docker:build-client": "docker build -f Dockerfile.client -t mpad-client .",
        "docker:build-server": "docker build -f Dockerfile.server -t mpad-server .",
        "docker:build-schema-migrate": "docker build -f Dockerfile.schema-migrate -t mpad-schema-migrate .",
        "docker:build-all": "bun run docker:build-client && bun run docker:build-server && bun run docker:build-schema-migrate",
        "docker:local-up": "./scripts/docker-local.sh up",
        "docker:local-down": "./scripts/docker-local.sh down",
        "docker:local-import": "./scripts/docker-local.sh import",
        "docker:local-test": "./scripts/docker-local.sh test",
        "client:test": "cd packages/client && bun run test",
        "server:test": "./scripts/docker-test-db.sh sh -lc 'cd packages/server && bun run schema-migrate && bun run test'",
        "e2e:test": "./scripts/run-playwright.sh --config playwright.config.ts",
        "typecheck": "turbo typecheck"
    },
    "devDependencies": {
        "@playwright/test": "^1.54.2",
        "turbo": "^2.9.4",
        "typescript": "^5.9"
    }
}
